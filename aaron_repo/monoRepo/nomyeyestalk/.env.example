# Copiar a .env y completar (no commitear .env)

# Worker Cloudflare (local o producción)
# Emulador Android: http://10.0.2.2:8787
# Simulador iOS: http://localhost:8787
# Teléfono físico: http://<IP-LAN-de-tu-Mac>:8787
EXPO_PUBLIC_WORKER_BASE_URL=http://localhost:8787

# Meta Wearables DAT — Wearables Developer Center
EXPO_PUBLIC_META_APP_ID=
EXPO_PUBLIC_META_CLIENT_TOKEN=

# Opcional — si worker tiene WORKER_API_KEY
# EXPO_PUBLIC_WORKER_API_KEY=

# Dev sin gafas: URI mp4 HEVC para MockDeviceKit (opcional)
# EXPO_PUBLIC_MOCK_VIDEO_URI=
